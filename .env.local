# ── Claude API (required for AI-powered keyword extraction + criteria parsing) ──
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── GitHub (optional but strongly recommended — raises rate limit from 60 to 5000 req/hr) ──
# Create a personal access token at https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

# ── free-ats sync (optional — only needed if you want to sync candidates to free-ats) ──
# Set these to your free-ats instance URL and login credentials
FREE_ATS_URL=
FREE_ATS_EMAIL=
FREE_ATS_PASSWORD=
