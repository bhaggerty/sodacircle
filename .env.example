NODE_ENV=production
PORT=8080
HOSTNAME=0.0.0.0

# AWS
AWS_REGION=us-west-2

# DynamoDB
DYNAMODB_TABLE_JOBS=sodacircle-jobs
DYNAMODB_TABLE_CANDIDATES=sodacircle-candidates
DYNAMODB_TABLE_JOB_CANDIDATES=sodacircle-job-candidates
DYNAMODB_TABLE_MESSAGES=sodacircle-messages
DYNAMODB_TABLE_FEEDBACK=sodacircle-feedback

# App
APP_URL=https://sodacircle.example.com

# Anthropic (Claude) — activates AI criteria extraction and candidate scoring when present.
# Without this key, the app falls back to regex-based extraction.
# Vend via Union Station (static or dynamic, set TTL as needed).
ANTHROPIC_API_KEY=sk-ant-...

# GitHub — optional but strongly recommended. Raises rate limit from 60 to 5000 req/hr.
# Create at: https://github.com/settings/tokens (no scopes needed, public data only)
GITHUB_TOKEN=ghp_...

# free-ats integration (https://github.com/bhaggerty/free-ats)
# Every profile surfaced in sodacircle is pushed to free-ats as the system of record.
# FREE_ATS_URL is the base URL of your running free-ats instance.
# FREE_ATS_EMAIL / FREE_ATS_PASSWORD are the credentials of a service account in that instance.
FREE_ATS_URL=http://localhost:3000
FREE_ATS_EMAIL=service@example.com
FREE_ATS_PASSWORD=your-ats-password
